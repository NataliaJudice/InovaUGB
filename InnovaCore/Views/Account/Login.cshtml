@using InnovaCore.ViewModels
@model ViewModelLogin



<style>
    /* RESET DE LAYOUT DO ASP.NET / BOOTSTRAP */
    main.container, .container-fluid, .container {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    body {
        background-color: #050505 !important;
        overflow-x: hidden;
    }

    /* WRAPPER PRINCIPAL OCUPANDO TODA A TELA */
    .auth-wrapper {
        min-height: 100vh;
        width: 100vw;
        background-color: #050505;
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1000;
        padding: 1rem;
    }

    /* CARD CYBERPUNK */
    .auth-card {
        background: #111;
        border: 1px solid #222;
        border-radius: 20px;
        box-shadow: 0 0 25px rgba(0, 229, 255, 0.15);
        width: 100%;
    }

        .auth-card h2 {
            color: #00e5ff;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-weight: 900;
            text-shadow: 0 0 10px rgba(0, 229, 255, 0.3);
        }

    /* INPUTS E LABELS */
    .cyber-input {
        background: #000 !important;
        border: 1px solid #333 !important;
        color: #fff !important;
        border-radius: 10px !important;
        padding: 0.8rem 1rem;
        transition: 0.3s;
    }

        .cyber-input:focus {
            border-color: #00e5ff !important;
            box-shadow: 0 0 12px rgba(0, 229, 255, 0.2) !important;
        }

    .form-check-label {
        color: #888;
        font-size: 0.8rem;
        cursor: pointer;
    }

    /* BOTÃO NEON */
    .btn-login {
        background: #00e5ff;
        color: #000;
        border: none;
        padding: 1rem;
        border-radius: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-login:hover {
            background: #fff;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.5);
            transform: translateY(-2px);
        }

    .register-link {
        color: #666;
        text-decoration: none;
        font-size: 0.85rem;
        transition: 0.3s;
    }

        .register-link:hover {
            color: #00e5ff;
        }
</style>

<div class="auth-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
                
                <div class="auth-card p-4 p-md-5">
                    <h2 class="text-center mb-4">Login</h2>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <input asp-for="Email" class="form-control cyber-input" placeholder="EMAIL OU USUÁRIO" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <input asp-for="Password" type="password" class="form-control cyber-input" placeholder="CHAVE DE ACESSO" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4 form-check d-flex align-items-center gap-2">
                            <input asp-for="rememberme" type="checkbox" class="form-check-input bg-dark border-secondary" id="rememberCheck" />
                            <label class="form-check-label" for="rememberCheck">MANTER CONEXÃO ATIVA</label>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn-login">Autenticar</button>
                            <a asp-action="Registrar" class="register-link text-center mt-2">
                                NÃO POSSUI ACESSO? REGISTRAR-SE NO SISTEMA
                            </a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

