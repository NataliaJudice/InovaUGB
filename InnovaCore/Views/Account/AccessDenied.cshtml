@{
    ViewData["Title"] = "Acesso Negado";
    Layout = "_Layout";
}

<style>
    :root {
        --bg-black: #050505;
        --card-bg: #0d1117;
        --cyan-neon: #00e5ff;
        --purple-neon: #7000ff;
        --text-gray: #888;
        --status-rejected: #ff4646;
    }

    body {
        background-color: var(--bg-black) !important;
        color: #fff;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    .error-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .error-card {
        background: var(--card-bg);
        border: 1px solid #1a1a1a;
        border-radius: 24px;
        padding: clamp(30px, 8vw, 60px);
        max-width: 500px;
        width: 100%;
        text-align: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    /* Linha de brilho no topo do card */
    .error-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--status-rejected), transparent);
    }

    .error-icon {
        font-size: clamp(4rem, 15vw, 6rem);
        color: var(--status-rejected);
        margin-bottom: 20px;
        filter: drop-shadow(0 0 15px rgba(255, 70, 70, 0.4));
        animation: pulse-red 2s infinite;
    }

    .error-card h1 {
        font-weight: 900;
        letter-spacing: -1px;
        font-size: clamp(1.5rem, 6vw, 2.2rem);
        text-transform: uppercase;
        margin-bottom: 15px;
    }

    .text-red-glow {
        color: var(--status-rejected);
        text-shadow: 0 0 10px rgba(255, 70, 70, 0.5);
    }

    .error-card p {
        color: var(--text-gray);
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 35px;
    }

    .btn-cyber-outline {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 25px;
        border: 1px solid #333;
        border-radius: 12px;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
        background: rgba(255, 255, 255, 0.03);
    }

    .btn-cyber-outline:hover {
        border-color: var(--cyan-neon);
        color: var(--cyan-neon);
        background: rgba(0, 229, 255, 0.05);
        transform: translateY(-2px);
    }

    .glitch-text {
        font-family: 'monospace';
        font-size: 0.7rem;
        color: #444;
        margin-top: 25px;
        text-transform: uppercase;
        letter-spacing: 4px;
    }

    @@keyframes pulse-red {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.05); opacity: 0.8; }
        100% { transform: scale(1); opacity: 1; }
    }

    @@media (max-width: 576px) {
        .error-card {
            padding: 40px 20px;
        }
    }
</style>

<div class="error-wrapper">
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        
        <h1>ACESSO <span class="text-red-glow">RESTRITO</span></h1>
        
        <p>
            O sistema de segurança InovaUGB detectou que você não possui as permissões necessárias para visualizar esta área.
        </p>

        <div class="d-flex flex-column gap-2">
            <a href="/" class="btn-cyber-outline">
                <i class="bi bi-house"></i> Voltar ao Início
            </a>
            <a href="javascript:history.back()" class="btn-cyber-outline" style="border-color: transparent;">
                 Tentar voltar
            </a>
        </div>

        <div class="glitch-text">
            Error: 403_Forbidden
        </div>
    </div>
</div>