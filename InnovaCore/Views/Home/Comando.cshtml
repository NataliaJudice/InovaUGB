@model InnovaCore.ViewModels.ViewModelDashboard
@using System.Globalization

@{
    ViewData["Title"] = "Terminal de Comando";
    Layout = "_Layout";

    // Materialização segura da lista e cálculo do valor de referência (100%)
    var listaSetores = Model.VwQtdePorSetor as IEnumerable<InnovaCore.Domain.Entities.VwQtdePorSetor> 
                       ?? new List<InnovaCore.Domain.Entities.VwQtdePorSetor>();
    
    var maxValor = listaSetores.Any() ? listaSetores.Max(x => x.QTDE_POR_SETOR ?? 0) : 0;
}

<style>
    :root {
        --bg-black: #050505;
        --card-bg: #0d1117;
        --accent-blue: #00b4d8;
        --accent-purple: #480ca8;
        --accent-green: #2d6a4f;
        --text-gray: #8b949e;
        --border-muted: #21262d;
    }

    body {
        background-color: var(--bg-black) !important;
        color: #f0f6fc;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    /* --- ANIMAÇÕES --- */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes growBar {
        from { height: 0; }
    }

    @@keyframes rotateIn {
        from { transform: rotate(-90deg); opacity: 0; }
        to { transform: rotate(0); opacity: 1; }
    }

    .animate-card {
        animation: fadeInUp 0.6s ease backwards;
    }

    /* --- LAYOUT --- */
    .dashboard-wrapper {
        padding: 2.5rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .dashboard-header h1 {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.5px;
        font-size: 2.2rem;
        animation: fadeInUp 0.5s ease;
    }

    /* --- METRIC CARDS --- */
    .metric-card {
        background: #0d1117;
        border: 1px solid var(--border-muted);
        border-radius: 20px;
        padding: 1.5rem;
        height: 100%;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .metric-card:hover {
        border-color: var(--accent-blue);
        background: #161b22;
        transform: translateY(-5px);
    }

    .metric-value {
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
        margin-top: 0.8rem;
        letter-spacing: -1.5px;
    }

    .icon-box-print {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    /* --- GRÁFICOS --- */
    .chart-container-print {
        background: #0d1117;
        border: 1px solid var(--border-muted);
        border-radius: 24px;
        padding: 2.5rem 2rem;
        height: 100%;
        animation: fadeInUp 0.8s ease backwards;
        animation-delay: 0.4s;
    }

    .bar-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        height: 100%;
        width: 100%;
        position: relative;
    }

    .bar-value {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--accent-blue);
        margin-bottom: 8px;
        opacity: 0;
        animation: fadeInUp 0.4s ease forwards;
    }

    .bar-print {
        width: 32px;
        background: linear-gradient(180deg, var(--accent-blue) 0%, #0077b6 100%);
        border-radius: 6px 6px 2px 2px;
        animation: growBar 1s cubic-bezier(0.17, 0.67, 0.83, 0.67) backwards;
    }

    .donut-print {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 20px solid #161b22;
        border-left-color: var(--accent-blue);
        border-top-color: var(--accent-purple);
        margin: 2rem auto;
        animation: rotateIn 1.2s ease-out backwards;
        animation-delay: 0.6s;
    }

    .label-caps {
        font-size: 0.7rem;
        letter-spacing: 1.5px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-gray);
    }

    .btn-action-main {
        background: #f0f6fc;
        color: #0d1117;
        font-weight: 700;
        font-size: 0.75rem;
        border-radius: 8px;
        padding: 10px 24px;
        border: none;
        transition: transform 0.2s;
    }
    .btn-action-main:hover { transform: scale(1.05); }
</style>

<div class="dashboard-wrapper">
    <div class="row align-items-center mb-5">
        <div class="col-md-8">
            <div class="dashboard-header">
                <h1>PAINEL DE CONTROLE</h1>
                <p class="text-secondary small mt-1">Telemetria de performance em tempo real.</p>
            </div>
        </div>
        <div class="col-md-4 text-md-end">
            <button class="btn btn-action-main">GERAR RELATÓRIO</button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.1s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(0, 180, 216, 0.15); color: var(--accent-blue);">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="label-caps">Total de Tarefas</div>
                <div class="metric-value text-white">@Model.VwDashboardQtde.TotalDeTarefas</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.2s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(72, 12, 168, 0.15); color: var(--accent-purple);">
                    <i class="bi bi-clock-fill"></i>
                </div>
                <div class="label-caps" style="color: var(--accent-purple);">Aguardando Resposta</div>
                <div class="metric-value">@Model.VwDashboardQtde.SolicitacoesPendentes</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.3s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(0, 255, 157, 0.15); color: #00ff9d;">
                    <i class="bi bi-activity"></i>
                </div>
                <div class="label-caps" style="color: #40916c;">Em Andamento</div>
                <div class="metric-value">@Model.VwDashboardQtde.TarefasEmAndamento</div>
            </div>
        </div>
        <div class="col-6 col-md-3 animate-card" style="animation-delay: 0.4s;">
            <div class="metric-card">
                <div class="icon-box-print" style="background: rgba(255, 255, 255, 0.05); color: #6e7681;">
                    <i class="bi bi-archive-fill"></i>
                </div>
                <div class="label-caps">A Fazer</div>
                <div class="metric-value" style="color: #6e7681;">@Model.VwDashboardQtde.TarefasAComecar</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="chart-container-print">
                <h5 class="fw-bold mb-5 text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;">Propostas por Setor</h5>
                <div class="d-flex align-items-end justify-content-around" style="height: 250px; padding-bottom: 10px; border-bottom: 1px solid var(--border-muted);">
                    
                    @if (listaSetores.Any())
                    {
                        double delayBarra = 0.5;
                        foreach (var item in listaSetores)
                        {
                            double alturaPercent = maxValor > 0 ? ((double)(item.QTDE_POR_SETOR ?? 0) / maxValor) * 100 : 0;
                            string delayNum = (delayBarra + 0.4).ToString("0.0", CultureInfo.InvariantCulture);
                            string delayBar = delayBarra.ToString("0.0", CultureInfo.InvariantCulture);

                            <div class="bar-wrapper">
                                <span class="bar-value" style="animation-delay: @(delayNum)s;">
                                    @item.QTDE_POR_SETOR
                                </span>
                                <div class="bar-print" 
                                     style="height: @alturaPercent.ToString("0.0", CultureInfo.InvariantCulture)%; 
                                            animation-delay: @(delayBar)s;"
                                     title="@item.Nome: @item.QTDE_POR_SETOR">
                                </div>
                                <span class="label-caps mt-3" style="font-size: 0.6rem; opacity: 0.6; white-space: nowrap;">
                                    @item.Nome
                                </span>
                            </div>
                            
                            delayBarra += 0.1;
                        }
                    }
                    else
                    {
                        <div class="text-center w-100 pb-5">
                            <p class="text-secondary opacity-50 m-0">Aguardando telemetria operacional...</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="chart-container-print text-center">
                <h5 class="fw-bold text-start text-uppercase mb-4" style="font-size: 0.85rem;">Conclusão Global</h5>
                <div class="donut-print"></div>
                <div class="mt-4">
                    <div class="label-caps mb-1">Taxa de Conclusão</div>
                    <span style="color: #fff; font-size: 2.5rem; font-weight: 800; letter-spacing: -1px;">94.2%</span>
                </div>
            </div>
        </div>
    </div>
</div>