@using System.Web
@model IEnumerable<InnovaCore.Domain.Entities.Setor>

@{
    Layout = "_Layout";
}

<style>
    :root {
        --bg-black: #050505;
        --card-bg: #0d1117;
        --cyan-neon: #00e5ff;
        --purple-neon: #7000ff;
        --text-gray: #a0a0a0;
        --input-bg: #161b22;
        --border-dim: #30363d;
        --error-neon: #ff0055;
    }

    body {
        background-color: var(--bg-black) !important;
        color: #fff;
        font-family: 'Inter', sans-serif;
        margin: 0;
        padding: 0;
    }

    .wrapper-protocolo {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh;
        padding: clamp(15px, 5vw, 40px);
    }

    .container-protocolo {
        width: 100%;
        max-width: 550px;
        background: var(--card-bg);
        padding: clamp(25px, 6vw, 45px);
        border-radius: 28px;
        border: 1px solid var(--border-dim);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .btn-voltar {
        color: var(--text-gray);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 30px;
        padding: 8px 0;
        transition: 0.3s;
    }

        .btn-voltar:hover {
            color: var(--cyan-neon);
        }

    .header-protocolo h1 {
        font-size: clamp(1.8rem, 7vw, 2.5rem);
        font-weight: 900;
        letter-spacing: -1px;
        margin-bottom: 10px;
        line-height: 1.1;
    }

    .text-cyan {
        color: var(--cyan-neon);
        text-shadow: 0 0 20px rgba(0, 229, 255, 0.3);
    }

    .subtitulo {
        color: var(--text-gray);
        font-size: 0.95rem;
        margin-bottom: 40px;
        line-height: 1.5;
    }

    .field-group {
        margin-bottom: 25px;
    }

    .label-cyber {
        display: block;
        color: var(--cyan-neon);
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 2px;
        margin-bottom: 10px;
        text-transform: uppercase;
        padding-left: 4px;
    }

    .input-cyber {
        width: 100%;
        background: var(--input-bg);
        border: 2px solid transparent;
        border-radius: 16px;
        padding: 18px;
        color: #fff;
        font-size: 1rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
        appearance: none;
    }

        .input-cyber:focus {
            outline: none;
            background: #0d1117;
            border-color: var(--cyan-neon);
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.1);
        }

    .textarea-cyber {
        min-height: 140px;
        line-height: 1.6;
        resize: vertical;
    }

    .btn-transmitir {
        width: 100%;
        background: linear-gradient(45deg, var(--cyan-neon), #00b8d4);
        color: #000;
        border: none;
        padding: 20px;
        border-radius: 18px;
        font-weight: 900;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        margin-top: 10px;
        transition: 0.4s;
    }

        .btn-transmitir:hover {
            filter: brightness(1.1);
            box-shadow: 0 0 30px rgba(0, 229, 255, 0.4);
        }

    /* Customização do SweetAlert2 */
    .swal-cyber-popup {
        border: 1px solid var(--border-dim) !important;
        border-radius: 28px !important;
        background: var(--card-bg) !important;
    }
</style>

<div class="wrapper-protocolo">
    <div class="container-protocolo">
        <div class="header-protocolo">
            <a href="javascript:history.back()" class="btn-voltar">
                <i class="bi bi-arrow-left-circle-fill"></i> Sair
            </a>
            <h1>NOVA <span class="text-cyan">PROPOSTA</span></h1>
            <p class="subtitulo">Preencha os dados abaixo para enviar sua proposta ao sistema.</p>
        </div>

        <form asp-action="Create" method="post" autocomplete="off" id="formProposta">
            @Html.AntiForgeryToken()

            <div class="field-group">
                <label class="label-cyber" for="Titulo">Título da proposta</label>
                <input id="Titulo" name="Titulo" type="text"
                       class="input-cyber"
                       placeholder="Ex: Sistema Aether 2.0"
                       required />
            </div>

            <div class="field-group">
                <label class="label-cyber" for="IdSetor">Setor de destino</label>
                <select id="IdSetor" name="IdSetor" class="input-cyber" required>
                    <option value="" disabled selected>Selecione o setor...</option>
                    @foreach (var tema in Model)
                    {
                        <option value="@tema.Id">@tema.Nome</option>
                    }
                </select>
            </div>

            <div class="field-group">
                <label class="label-cyber" for="Descricao">Descrição da proposta</label>
                <textarea id="Descricao" name="Descricao"
                          class="input-cyber textarea-cyber"
                          placeholder="Descreva detalhadamente o objetivo desta proposta..."
                          required></textarea>
            </div>

            <button type="submit" class="btn-transmitir">
                <span> TRANSMITIR AGORA</span>
                <i class="bi bi-broadcast-pin" style="font-size: 1.2rem;"></i>
            </button>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // 1. Notificações de Erro/Sucesso vindo do Servidor
        @if (TempData["ErrorMessage"] != null || ViewBag.Error != null)
        {
                var msg = TempData["ErrorMessage"] ?? ViewBag.Error;
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Erro na Transmissão',
                    text: '@msg',
                    background: '#0d1117',
                    color: '#fff',
                    confirmButtonColor: '#ff0055',
                    customClass: { popup: 'swal-cyber-popup' }
                });
                </text>
        }

        // 2. Interceptação do Formulário para Confirmação
        const form = document.getElementById('formProposta');

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: 'Confirmar Envio?',
                text: "Sua proposta será enviada para análise técnica e e-mails serão disparados.",
                icon: 'question',
                showCancelButton: true,
                background: '#0d1117',
                color: '#fff',
                confirmButtonColor: '#00e5ff',
                cancelButtonColor: '#30363d',
                confirmButtonText: 'Sim, transmitir!',
                cancelButtonText: 'Cancelar',
                customClass: { popup: 'swal-cyber-popup' }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Processando...',
                        html: 'Sincronizando dados com a rede InovaUGB.',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); },
                        background: '#0d1117',
                        color: '#fff',
                        customClass: { popup: 'swal-cyber-popup' }
                    });
                    form.submit();
                }
            });
        });
    });
</script>